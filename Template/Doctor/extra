{% block docContent %}
<div class="container">
    <img src="{% static 'assets/img/doctors/image1.jpg' %}" alt="doctor prescription" class="form-image img-fluid">
    <h2 class="card-title">Doctor Prescription</h2>
    <div class="containerBox">
      <form id="prescription-form" method="post">
        {% csrf_token %}
        {% if form %}
        <div class="form-group">
            <label for="patient-name" class="large-label">Patient Name</label>
            <!-- <input type="text" id="patient-name" class="form-control large-textbox" name="patient-name" placeholder="Enter patient name" required> -->
            
            <div class="error" id="name-error"></div>
        </div>
        <div class="form-group">
            <label for="patient-age" class="large-label">Patient Age</label>
            <input type="number" id="patient-age" class="form-control large-textbox" name="patient-age" placeholder="Enter patient age" required>
            <div class="error" id="age-error"></div>
        </div>
        <!-- <div class="form-group">
            <label for="patient-phone" class="large-label">Phone</label>
            <input type="tel" id="patient-phone" class="form-control large-textbox" name="patient-phone" placeholder="Enter phone number" required>
            <div class="error" id="phone-error"></div>
        </div> -->
        <div class="form-group">
            <label class="large-label">Gender</label>
            <div class="radio-group">
                <label class="large-label">
                  <input type="radio" name="gender" value="male" required> Male</label>
                <label class="large-label"><input type="radio" name="gender" value="female"> Female</label>
                <label class="large-label"><input type="radio" name="gender" value="other"> Other</label>
            </div>
            <div class="error" id="gender-error"></div>
        </div>
        <div class="form-group">
            <label for="diagnosis" class="large-label">Diagnosis</label>
            <textarea id="diagnosis" name="diagnosis" rows="3" class="form-control large-textbox" placeholder="Enter diagnosis details" required></textarea>
            <div class="error" id="diagnosis-error"></div>
        </div>
        <div class="form-group">
            <label for="prescription" class="large-label">Prescription</label>
            <textarea id="prescription" name="prescription" rows="3" class="form-control large-textbox" placeholder="Enter prescription details" required></textarea>
            <div class="error" id="prescription-error"></div>
        </div>
        
        <div class="form-group" >
          <label class="large-label">OPD/IPD</label>
          <div class="radio-group">
              <label class="large-label"><input type="radio" name="gender" value="IPD" required> IPD</label>
              <label class="large-label"><input type="radio" name="gender" value="OPD"> OPD</label>
              <!-- <label class="large-label"><input type="radio" name="gender" value="other"> Other</label> -->
          </div>
          <div class="error" id="gender-error"></div>
      </div>
        <!-- <div class="form-group">
            <input type="checkbox" id="certification" name="certification" class="large-textbox" required>
            <label class="large-label" for="certification">I certify that the above information is true and accurate</label>
            <div class="error" id="certification-error"></div>
        </div> -->
        <button type="submit" class="btn btn-primary">Submit</button>
        {% endform %}
    </form>
    </div>
</div>
{% endblock %}
