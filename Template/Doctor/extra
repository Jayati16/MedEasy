{% extends 'Doctor/common.html' %}
{% load static %}

{% block css %}
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
<style>
    .form-image {
        max-width: 100vw;
        width: 100%;
        max-height: 65vh;
        position: relative;
        filter: brightness(50%); /* Makes the image darker */
    }

    .container {
        padding: 0;
        position: relative;
        
    }

    .container h2 {
        position: absolute;
        top: 15%;
        left: 49%;
        transform: translate(-50%, -50%);
        color: #fff;
        font-size: 2.5rem;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7); /* Highlighted text */
        text-align: center;
    }

    .containerBox {
        padding: 15px;
    }

    .form-group .error {
        color: red;
        font-size: 0.9rem;
    }
</style>
{% endblock %}

